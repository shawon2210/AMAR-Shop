generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =================== ENUMS ===================

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
  LOGISTICS
  MODERATOR
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  PARTIALLY_SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PaymentMethod {
  BKASH
  NAGAD
  COD
  SSLCOMMERZ
  WALLET
}

enum ShipmentStatus {
  PENDING
  PICKUP_SCHEDULED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAWAL
  PURCHASE
  REFUND
  CASHBACK
  REFERRAL
  COMMISSION
  PAYOUT
  ADJUSTMENT
}

enum SellerLevel {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum CampaignType {
  FLASH_SALE
  MEGA_DEALS
  SELLER_CAMPAIGN
  DAILY_DEAL
  FREE_SHIPPING
}

enum NotificationType {
  ORDER_UPDATE
  PROMOTION
  SYSTEM
  CHAT_MESSAGE
  WALLET
  FOLLOW
  CAMPAIGN
}

// =================== REVIEWS ===================

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  images    String[]
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model FlashSaleProduct {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  flashSalePrice Float
  quantity  Int      @default(0)
  sold      Int      @default(0)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
}

// =================== USER & AUTH ===================

model User {
  id              String     @id @default(cuid())
  name            String
  email           String?    @unique
  phone           String     @unique
  password        String
  avatar          String?
  role            UserRole   @default(CUSTOMER)
  isSeller        Boolean    @default(false)
  isActive        Boolean    @default(true)
  isVerified      Boolean    @default(false)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret String?
  lastLoginAt     DateTime?
  deviceTokens    String[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  sellerProfile   SellerProfile?
  store           Store?
  cart            CartItem[]
  addresses       Address[]
  orders          Order[]
  reviews         Review[]
  conversations   Conversation[]   @relation("UserConversations")
  messages        Message[]
  notifications   Notification[]
  wishlist        WishlistItem[]
  searchHistory   SearchHistory[]
  browsingHistory BrowsingHistory[]
  activities      UserActivity[]
  tickets         SupportTicket[]
  wallet          Wallet?
  walletTxns      WalletTransaction[]
  loyaltyPoints   LoyaltyPoint[]
  rewardHistory   RewardHistory[]
  adminLogs       AdminLog[]
  userPermissions UserPermission[]
  storeFollowers  StoreFollower[]  @relation("StoreFollowerUser")
  paymentTransactions PaymentTransaction[]
  disputes        Dispute[]
  couponUsages    CouponUsage[]
  productQuestions ProductQuestion[]
  affiliateProfile  AffiliateProfile?
  pushDevices       PushDevice[]
  apiKeys           ApiKey[]
}

// =================== SELLER ECOSYSTEM ===================

model SellerProfile {
  id                  String      @id @default(cuid())
  userId              String      @unique
  user                User        @relation(fields: [userId], references: [id])
  businessName        String?
  businessAddress     String?
  businessType        String?
  taxId               String?
  tradeLicense        String?
  nidNumber           String?
  nidImageFront       String?
  nidImageBack        String?
  bankName            String?
  bankAccountName     String?
  bankAccountNumber   String?
  bankRoutingNumber   String?
  bkashNumber         String?
  nagadNumber         String?
  isKycVerified       Boolean     @default(false)
  kycSubmittedAt      DateTime?
  kycVerifiedAt       DateTime?
  kycRejectedReason   String?
  level               SellerLevel @default(BRONZE)
  performanceScore    Float       @default(0)
  totalOrders         Int         @default(0)
  totalRevenue        Float       @default(0)
  totalProducts       Int         @default(0)
  totalFollowers      Int         @default(0)
  avgRating           Float       @default(0)
  responseRate        Float       @default(0)
  responseTime        Int         @default(0)
  onVacation          Boolean     @default(false)
  vacationMessage     String?
  vacationUntil       DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  store Store?
}


model Store {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  description     String?
  logo            String?
  banner          String?
  isOfficial      Boolean       @default(false)
  isActive        Boolean       @default(true)
  commission      Float         @default(5.0)
  commissionRate  Float         @default(5.0)
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id])
  sellerProfileId String?       @unique
  sellerProfile   SellerProfile? @relation(fields: [sellerProfileId], references: [id])
  badge           String?
  followerCount   Int           @default(0)
  rating          Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  products        Product[]
  followers       StoreFollower[]
  conversations   Conversation[]  @relation("StoreConversations")
  campaigns       Campaign[]
  banners         Banner[]
  payouts         SellerPayout[]
  commissions     Commission[]
  sellerSettlements SellerSettlement[]
  invoices          Invoice[]
}

model StoreFollower {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  userId    String
  user      User     @relation("StoreFollowerUser", fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([storeId, userId])
}

// =================== PRODUCT & CATALOG ===================

model Category {
  id            String       @id @default(cuid())
  name          String
  bnName        String?
  slug          String       @unique
  icon          String?
  description   String?
  image         String?
  parentId      String?
  parent        Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      Category[]   @relation("CategoryHierarchy")
  productCount  Int          @default(0)
  isActive      Boolean      @default(true)
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())

  products      Product[]
  attributes    Attribute[]
}

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  logo        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  products    Product[]
}

model Product {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  description     String?
  shortDescription String?
  price           Float
  originalPrice   Float?
  currency        String    @default("BDT")
  images          String[]
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id])
  storeId         String
  store           Store     @relation(fields: [storeId], references: [id])
  brandId         String?
  brand           Brand?    @relation(fields: [brandId], references: [id])
  rating          Float     @default(0)
  reviewCount     Int       @default(0)
  inStock         Boolean   @default(true)
  stockCount      Int       @default(0)
  soldCount       Int       @default(0)
  isFlashSale     Boolean   @default(false)
  isNew           Boolean   @default(false)
  isFeatured      Boolean   @default(false)
  freeShipping    Boolean   @default(false)
  flashSalePrice  Float?
  flashSaleEndsAt DateTime?
  soldPercent     Int?
  minOrderQty     Int       @default(1)
  maxOrderQty     Int?
  weight          Float?
  length          Float?
  width           Float?
  height          Float?
  seoTitle        String?
  seoDescription  String?
  status          String    @default("active") // active | inactive | pending | rejected
  rejectReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  cartItems        CartItem[]
  orderItems       OrderItem[]
  reviews          Review[]
  variants         ProductVariant[]
  productImages    ProductImage[]
  attributes       ProductAttribute[]
  questions        ProductQuestion[]
  flashSaleProducts FlashSaleProduct[]
  campaignProducts  CampaignProduct[]
  wishlistItems    WishlistItem[]
  inventory        Inventory[]
  browsingHistories BrowsingHistory[]
  returnRequests   ReturnRequest[]
  inboundOrderItems       InboundOrderItem[]
  pickListItems           PickListItem[]
  packageItems            PackageItem[]
  warehouseTransferItems  WarehouseTransferItem[]
  invoiceItems            InvoiceItem[]
  affiliateLinks          AffiliateLink[]
  affiliateClicks         AffiliateClick[]
  affiliateConversions    AffiliateConversion[]
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  name      String   // e.g. "128GB Black", "256GB White"
  sku       String   @unique
  price     Float?
  stock     Int      @default(0)
  image     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  orderItems OrderItem[]
  pickListItems     PickListItem[]
  @@unique([productId, name])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Attribute {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  categoryId  String?
  category    Category?        @relation(fields: [categoryId], references: [id])
  values      AttributeValue[]
  createdAt    DateTime @default(now())
}

// =================== WMS - WAREHOUSE MANAGEMENT ===================

model BinLocation {
  id          String   @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  zone        String   // A, B, C, D
  aisle       String
  rack        String
  shelf       String
  code        String   @unique // e.g. "A-01-01-01"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventory   InventoryBin[]
  pickItems   PickListItem[]
  cycleItems  CycleCountItem[]
  inboundOrderItems InboundOrderItem[]
}

model InventoryBin {
  id          String   @id @default(cuid())
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
  binId       String
  bin         BinLocation @relation(fields: [binId], references: [id])
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([inventoryId, binId])
}

model InboundOrder {
  id            String   @id @default(cuid())
  orderNumber   String   @unique
  warehouseId   String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  supplierName  String?
  supplierRef   String?
  status        String   @default("PENDING") // PENDING | RECEIVING | COMPLETED | CANCELLED
  notes         String?
  receivedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         InboundOrderItem[]
}

model InboundOrderItem {
  id              String   @id @default(cuid())
  inboundOrderId  String
  inboundOrder    InboundOrder @relation(fields: [inboundOrderId], references: [id])
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  expectedQty     Int
  receivedQty     Int      @default(0)
  damagedQty      Int      @default(0)
  unitCost        Float    @default(0)
  binId           String?
  bin             BinLocation? @relation(fields: [binId], references: [id])
  createdAt       DateTime @default(now())
}

model PickList {
  id          String   @id @default(cuid())
  pickNumber  String   @unique
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  status      String   @default("OPEN") // OPEN | IN_PROGRESS | COMPLETED | CANCELLED
  assignedTo  String?
  priority    String   @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  notes       String?
  pickedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       PickListItem[]
}

model PickListItem {
  id            String     @id @default(cuid())
  pickListId    String
  pickList      PickList   @relation(fields: [pickListId], references: [id])
  orderId       String
  order         Order      @relation(fields: [orderId], references: [id])
  productId     String
  product       Product    @relation(fields: [productId], references: [id])
  variantId     String?
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  quantity      Int
  pickedQty     Int        @default(0)
  binId         String?
  bin           BinLocation? @relation(fields: [binId], references: [id])
  status        String     @default("PENDING") // PENDING | PICKED | SKIPPED
  pickedAt      DateTime?
  createdAt     DateTime   @default(now())
}

model Package {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  packageNumber String @unique
  weight      Float?
  length      Float?
  width       Float?
  height      Float?
  status      String   @default("PENDING") // PENDING | PACKED | LABELED | SHIPPED
  trackingId  String?
  labelUrl    String?
  packedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       PackageItem[]
}

model PackageItem {
  id        String   @id @default(cuid())
  packageId String
  package   Package  @relation(fields: [packageId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  createdAt DateTime @default(now())
}

model WarehouseTransfer {
  id                String   @id @default(cuid())
  transferNumber    String   @unique
  fromWarehouseId   String
  fromWarehouse     Warehouse @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId     String
  toWarehouse       Warehouse @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  status            String   @default("PENDING") // PENDING | IN_TRANSIT | RECEIVED | CANCELLED
  notes             String?
  shippedAt         DateTime?
  receivedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  items             WarehouseTransferItem[]
}

model WarehouseTransferItem {
  id             String   @id @default(cuid())
  transferId     String
  transfer       WarehouseTransfer @relation(fields: [transferId], references: [id])
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  quantity       Int
  receivedQty    Int      @default(0)
  createdAt      DateTime @default(now())
}

model CycleCount {
  id          String   @id @default(cuid())
  countNumber String   @unique
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  zone        String?
  status      String   @default("OPEN") // OPEN | IN_PROGRESS | COMPLETED | REVIEWED
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       CycleCountItem[]
}

model CycleCountItem {
  id              String   @id @default(cuid())
  cycleCountId    String
  cycleCount      CycleCount @relation(fields: [cycleCountId], references: [id])
  inventoryId     String
  inventory       Inventory @relation(fields: [inventoryId], references: [id])
  binId           String?
  bin             BinLocation? @relation(fields: [binId], references: [id])
  expectedQty     Int
  actualQty       Int
  variance        Int
  isAdjusted      Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())
}

model DamagedInventory {
  id          String   @id @default(cuid())
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
  quantity    Int
  reason      String
  reportedBy  String?
  status      String   @default("PENDING") // PENDING | APPROVED | DISPOSED
  disposedAt  DateTime?
  createdAt   DateTime @default(now())
}

// =================== FINANCE & ACCOUNTING ===================

model EscrowTransaction {
  id          String   @id @default(cuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])
  amount      Float
  status      String   @default("HELD") // HELD | RELEASED | REFUNDED | PARTIALLY_REFUNDED
  heldAt      DateTime @default(now())
  releasedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SellerSettlement {
  id              String   @id @default(cuid())
  settlementNumber String  @unique
  sellerId        String
  seller          Store    @relation(fields: [sellerId], references: [id])
  periodStart     DateTime
  periodEnd       DateTime
  grossAmount     Float
  commission      Float
  fee             Float
  netAmount       Float
  status          String   @default("PENDING") // PENDING | PROCESSING | COMPLETED | FAILED
  method          String?  // bank | bkash | nagad
  accountNumber   String?
  reference       String?
  processedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           SettlementItem[]
}

model SettlementItem {
  id            String   @id @default(cuid())
  settlementId  String
  settlement    SellerSettlement @relation(fields: [settlementId], references: [id])
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  amount        Float
  commission    Float
  fee           Float
  netAmount     Float
  createdAt     DateTime @default(now())
}

model AccountingEntry {
  id              String   @id @default(cuid())
  entryNumber     String   @unique
  type            String   // DEBIT | CREDIT
  account         String   // e.g. "CASH", "BANK", "ACCOUNTS_RECEIVABLE", "REVENUE", "COMMISSION_INCOME"
  amount          Float
  description     String?
  referenceId     String?
  referenceType   String?  // order | settlement | payout | invoice
  entryDate       DateTime
  createdAt       DateTime @default(now())
}

model Invoice {
  id          String   @id @default(cuid())
  invoiceNumber String @unique
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  sellerId    String
  seller      Store    @relation(fields: [sellerId], references: [id])
  subtotal    Float
  tax         Float    @default(0)
  discount    Float    @default(0)
  total       Float
  status      String   @default("DRAFT") // DRAFT | SENT | PAID | CANCELLED
  dueDate     DateTime?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       InvoiceItem[]
}

model InvoiceItem {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  total     Float
  createdAt DateTime @default(now())
}

model CreditNote {
  id              String   @id @default(cuid())
  creditNoteNumber String  @unique
  returnId        String   @unique
  returnRequest   ReturnRequest @relation(fields: [returnId], references: [id])
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])
  amount          Float
  reason          String?
  status          String   @default("DRAFT") // DRAFT | ISSUED | APPLIED | CANCELLED
  issuedAt        DateTime?
  appliedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// =================== FULFILLMENT NETWORK ===================

model DeliverySlot {
  id          String   @id @default(cuid())
  courierId   String
  courier     Courier  @relation(fields: [courierId], references: [id])
  pincode     String
  dayOfWeek   Int      // 0=Sunday .. 6=Saturday
  startTime   String   // "09:00"
  endTime     String   // "17:00"
  maxOrders   Int      @default(50)
  bookedOrders Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model CourierPerformanceLog {
  id          String   @id @default(cuid())
  courierId   String
  courier     Courier  @relation(fields: [courierId], references: [id])
  date        DateTime
  totalShipments Int   @default(0)
  delivered   Int      @default(0)
  failed      Int      @default(0)
  returned    Int      @default(0)
  onTime      Int      @default(0)
  avgDeliveryTime Float? // hours
  codCollected Float   @default(0)
  codRemitted  Float   @default(0)
  createdAt   DateTime @default(now())

  @@unique([courierId, date])
}

// =================== BI & ANALYTICS ===================

model ScheduledReport {
  id          String   @id @default(cuid())
  name        String
  type        String   // executive | rfm | retention | seller | product | custom
  config      Json
  cron        String   // cron expression
  recipients  String[] // email addresses
  format      String   @default("PDF") // PDF | EXCEL | CSV
  lastSentAt  DateTime?
  nextRunAt   DateTime?
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CohortAnalysis {
  id          String   @id @default(cuid())
  cohort      String   // e.g. "2024-01"
  period      String   // monthly | quarterly
  totalUsers  Int      @default(0)
  retention_1  Float   @default(0)
  retention_2  Float   @default(0)
  retention_3  Float   @default(0)
  retention_6  Float   @default(0)
  retention_12 Float   @default(0)
  createdAt   DateTime @default(now())
}

model RfmSegment {
  id          String   @id @default(cuid())
  segment     String   // "Champions", "Loyal", "At Risk", etc.
  minRecency  Int
  maxRecency  Int
  minFrequency Int
  maxFrequency Int
  minMonetary  Float
  maxMonetary  Float
  userCount   Int      @default(0)
  avgLtv      Float    @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model AttributeValue {
  id          String           @id @default(cuid())
  attributeId String
  attribute   Attribute        @relation(fields: [attributeId], references: [id])
  value       String
  productAttributes ProductAttribute[]
}

model ProductAttribute {
  id              String         @id @default(cuid())
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  attributeValueId String
  attributeValue  AttributeValue @relation(fields: [attributeValueId], references: [id])

  @@unique([productId, attributeValueId])
}

// =================== CART & WISHLIST ===================

model CartItem {
  id        String   @id @default(cuid())
  quantity  Int      @default(1)
  selected  Boolean  @default(true)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

// =================== ORDER & SHIPPING ===================

model Address {
  id        String    @id @default(cuid())
  label     String?
  fullName  String
  phone     String
  street    String
  city      String
  area      String?
  district  String?
  division  String?
  zipCode   String?
  isDefault Boolean   @default(false)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())

  orders Order[]
}

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  status         OrderStatus   @default(PENDING)
  subtotal       Float
  shipping       Float         @default(0)
  discount       Float         @default(0)
  total          Float
  paymentMethod  PaymentMethod
  paymentStatus  Boolean       @default(false)
  paidAt         DateTime?
  note           String?
  trackingNumber String?
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  addressId      String
  address        Address       @relation(fields: [addressId], references: [id])
  couponId       String?
  coupon         Coupon?       @relation(fields: [couponId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items          OrderItem[]
  shipments      Shipment[]
  payment        PaymentTransaction?
  refund         Refund?
  returnRequest  ReturnRequest?
  dispute        Dispute?
  commissions    Commission[]
  pickListItems     PickListItem[]
  packages          Package[]
  escrowTransaction EscrowTransaction?
  settlementItems   SettlementItem[]
  invoices          Invoice[]
  creditNotes       CreditNote[]
  affiliateConversions AffiliateConversion[]
}

model OrderItem {
  id        String   @id @default(cuid())
  quantity  Int
  price     Float
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  createdAt DateTime @default(now())
}

// =================== LOGISTICS ===================

model Courier {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  apiKey      String?
  apiSecret   String?
  isActive    Boolean  @default(true)
  baseRate    Float    @default(0)
  perKgRate   Float    @default(0)
  codFee      Float    @default(0)
  deliveryDays String?
  logo        String?
  createdAt   DateTime @default(now())

  shipments   Shipment[]
  zones       DeliveryZone[]
  deliverySlots     DeliverySlot[]
  performanceLogs   CourierPerformanceLog[]
}

model DeliveryZone {
  id        String   @id @default(cuid())
  courierId String
  courier   Courier  @relation(fields: [courierId], references: [id])
  name      String
  districts String[]
  baseFee   Float
  codFee    Float
  estDays   String
  isActive  Boolean  @default(true)
}

model Shipment {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  courierId       String?
  courier         Courier?      @relation(fields: [courierId], references: [id])
  trackingId      String?       @unique
  labelUrl        String?
  status          ShipmentStatus @default(PENDING)
  pickupAddress   String?
  deliveryAddress String?
  weight          Float?
  codAmount       Float?
  shippingFee     Float?
  estimatedDays   String?
  pickedAt        DateTime?
  deliveredAt     DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  timeline        ShipmentTimeline[]
}

model ShipmentTimeline {
  id        String        @id @default(cuid())
  shipmentId String
  shipment  Shipment      @relation(fields: [shipmentId], references: [id])
  status    ShipmentStatus
  location  String?
  note      String?
  createdAt DateTime      @default(now())
}

model Warehouse {
  id          String   @id @default(cuid())
  name        String
  address     String
  city        String
  division    String
  managerName String?
  phone       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  inventory   Inventory[]
  binLocations      BinLocation[]
  inboundOrders     InboundOrder[]
  pickLists         PickList[]
  cycleCounts       CycleCount[]
  fromTransfers     WarehouseTransfer[]  @relation("FromWarehouse")
  toTransfers       WarehouseTransfer[]  @relation("ToWarehouse")
}

model Inventory {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  quantity     Int      @default(0)
  reservedQty  Int      @default(0)
  lowStockQty  Int      @default(10)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movements    InventoryMovement[]
  inventoryBins     InventoryBin[]
  cycleCountItems   CycleCountItem[]
  damagedItems      DamagedInventory[]

  @@unique([productId, warehouseId])
}

model InventoryMovement {
  id          String   @id @default(cuid())
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
  type        String   // IN | OUT | ADJUSTMENT | RESERVED | RELEASED
  quantity    Int
  reference   String?  // order ID, adjustment note
  note        String?
  createdAt   DateTime @default(now())
}

// =================== PAYMENTS & WALLET ===================

model PaymentTransaction {
  id              String        @id @default(cuid())
  orderId         String?       @unique
  order           Order?        @relation(fields: [orderId], references: [id])
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  amount          Float
  fee             Float         @default(0)
  netAmount       Float
  method          PaymentMethod
  provider        String?       // bkash | nagad | sslcommerz
  transactionId   String?       // gateway transaction ID
  referenceId     String?
  status          String        @default("PENDING") // PENDING | SUCCESS | FAILED | REFUNDED
  responseData    Json?
  createdAt       DateTime      @default(now())

  refund          Refund?
}

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  balance       Float    @default(0)
  totalEarned   Float    @default(0)
  totalSpent    Float    @default(0)
  bonusBalance  Float    @default(0)
  cashbackBalance Float  @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions  WalletTransaction[]
}

model WalletTransaction {
  id          String               @id @default(cuid())
  walletId    String
  wallet      Wallet               @relation(fields: [walletId], references: [id])
  userId      String?
  user        User?                @relation(fields: [userId], references: [id])
  type        WalletTransactionType
  amount      Float
  fee         Float                @default(0)
  balanceBefore Float
  balanceAfter  Float
  reference   String?
  description String?
  status      String               @default("COMPLETED")
  createdAt   DateTime             @default(now())
}

// =================== REFUNDS & RETURNS ===================

model Refund {
  id            String        @id @default(cuid())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id])
  amount        Float
  reason        String?
  status        String        @default("PENDING") // PENDING | APPROVED | REJECTED | PROCESSED
  paymentTxnId  String?       @unique
  paymentTxn    PaymentTransaction? @relation(fields: [paymentTxnId], references: [id])
  processedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ReturnRequest {
  id          String   @id @default(cuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int      @default(1)
  reason      String
  description String?
  images      String[]
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED | PICKED_UP | REFUNDED
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creditNote        CreditNote?
}

model Dispute {
  id          String   @id @default(cuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  subject     String
  description String
  status      String   @default("OPEN") // OPEN | IN_REVIEW | RESOLVED | CLOSED
  resolution  String?
  resolvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    Message[]
}

// =================== SELLER FINANCE ===================

model SellerPayout {
  id              String   @id @default(cuid())
  sellerId        String
  seller          Store    @relation(fields: [sellerId], references: [id])
  amount          Float
  fee             Float    @default(0)
  netAmount       Float
  method          String   // bank | bkash | nagad
  accountNumber   String?
  status          String   @default("PENDING") // PENDING | PROCESSING | COMPLETED | FAILED
  reference       String?
  processedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Commission {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  sellerId    String
  seller      Store    @relation(fields: [sellerId], references: [id])
  amount      Float
  rate        Float
  status      String   @default("PENDING") // PENDING | RELEASED | REFUNDED
  releasedAt  DateTime?
  createdAt   DateTime @default(now())
}

// =================== COUPONS & PROMOTIONS ===================

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   // PERCENTAGE | FIXED | FREE_SHIPPING
  value       Float
  minPurchase Float    @default(0)
  maxUses     Int?
  usedCount   Int      @default(0)
  maxPerUser  Int      @default(1)
  isActive    Boolean  @default(true)
  startsAt    DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  orders      Order[]
  usage       CouponUsage[]
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  orderId   String?
  discount  Float
  createdAt DateTime @default(now())

  @@unique([couponId, userId])
}

// =================== CAMPAIGNS ===================

model Campaign {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  type        CampaignType
  description String?
  banner      String?
  status      String        @default("DRAFT") // DRAFT | ACTIVE | ENDED
  startsAt    DateTime?
  endsAt      DateTime?
  storeId     String?
  store       Store?        @relation(fields: [storeId], references: [id])
  discount    Float?
  maxProducts Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  products    CampaignProduct[]
}

model CampaignProduct {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  salePrice   Float?
  discount    Float?
  quantity    Int?
  sold        Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([campaignId, productId])
}

// =================== SOCIAL & ENGAGEMENT ===================

model ProductQuestion {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  question      String
  answer        String?
  answeredBy    String?
  answeredAt    DateTime?
  createdAt     DateTime @default(now())

  answers       ProductAnswer[]
}

model ProductAnswer {
  id        String   @id @default(cuid())
  questionId String
  question  ProductQuestion @relation(fields: [questionId], references: [id])
  answer    String
  userId    String
  createdAt DateTime @default(now())
}

// =================== NOTIFICATIONS & CHAT ===================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime          @default(now())
}

model Conversation {
  id        String   @id @default(cuid())
  storeId   String?
  store     Store?   @relation("StoreConversations", fields: [storeId], references: [id])
  userId    String?
  user      User?    @relation("UserConversations", fields: [userId], references: [id])
  subject   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User     @relation(fields: [senderId], references: [id])
  content        String
  attachments    String[]
  read           Boolean  @default(false)
  readAt         DateTime?
  supportTicketId String?
  supportTicket  SupportTicket? @relation(fields: [supportTicketId], references: [id])
  disputeId      String?
  dispute        Dispute?   @relation(fields: [disputeId], references: [id])
  createdAt      DateTime @default(now())
}

// =================== SUPPORT ===================

model SupportTicket {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  subject     String
  description String
  category    String?      // ORDER | PAYMENT | TECHNICAL | ACCOUNT | OTHER
  priority    String       @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  status      TicketStatus @default(OPEN)
  assignedTo  String?
  resolution  String?
  rating      Int?
  feedback    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  messages    Message[]
}

model FAQ {
  id          String   @id @default(cuid())
  question    String
  answer      String
  category    String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// =================== LOYALTY & REWARDS ===================

model LoyaltyPoint {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  points    Int      @default(0)
  tier      String   @default("REGULAR") // REGULAR | SILVER | GOLD | PLATINUM
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RewardHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // EARNED | REDEEMED | EXPIRED
  points      Int
  reference   String?
  description String?
  createdAt   DateTime @default(now())
}

// =================== CMS & CONTENT ===================

model Banner {
  id          String   @id @default(cuid())
  title       String?
  image       String
  link        String?
  position    String   // HOME_TOP | HOME_MID | HOME_BOTTOM | CATEGORY | SIDEBAR
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  storeId     String?
  store       Store?   @relation(fields: [storeId], references: [id])
  createdAt   DateTime @default(now())
}

model CMSPage {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String?
  metaTitle   String?
  metaDesc    String?
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   // INFO | WARNING | PROMO
  isActive  Boolean  @default(true)
  expiresAt DateTime?
  createdAt DateTime @default(now())
}

// =================== ANALYTICS & ACTIVITY ===================

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  query     String
  results   Int?
  createdAt DateTime @default(now())
}

model BrowsingHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // VIEW_PRODUCT | ADD_TO_CART | PURCHASE | SEARCH | LOGIN
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// =================== ADMIN & SECURITY ===================

model Role {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  isSystem    Boolean        @default(false)
  createdAt   DateTime       @default(now())

  permissions RolePermission[]
  userPermissions UserPermission[]
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  module      String?  // products | orders | users | settings
  createdAt   DateTime @default(now())

  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model UserPermission {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

// =================== AFFILIATE MARKETPLACE ===================

model AffiliateProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  referralCode  String   @unique
  bio           String?
  socialLinks   String[]
  promoMethods  String[]
  status        String   @default("PENDING") // PENDING | ACTIVE | SUSPENDED
  totalEarned   Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  links         AffiliateLink[]
  clicks        AffiliateClick[]
  conversions   AffiliateConversion[]
  commissions   AffiliateCommission[]
  payouts       AffiliatePayout[]
  campaigns     AffiliateCampaign[]
}

model AffiliateLink {
  id          String   @id @default(cuid())
  shortCode   String   @unique
  affiliateId String
  affiliate   AffiliateProfile @relation(fields: [affiliateId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  campaign    String?
  url         String
  deepLink    String?
  isActive    Boolean  @default(true)
  clicksCount Int      @default(0)
  convCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clicks      AffiliateClick[]
  conversions AffiliateConversion[]
}

model AffiliateClick {
  id          String   @id @default(cuid())
  affiliateId String
  affiliate   AffiliateProfile @relation(fields: [affiliateId], references: [id])
  linkId      String
  link        AffiliateLink @relation(fields: [linkId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  referrer    String?
  device      String?
  location    String?
  ip          String?
  converted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  conversions       AffiliateConversion[]
}

model AffiliateConversion {
  id            String   @id @default(cuid())
  affiliateId   String
  affiliate     AffiliateProfile @relation(fields: [affiliateId], references: [id])
  linkId        String
  link          AffiliateLink @relation(fields: [linkId], references: [id])
  clickId       String   @unique
  click         AffiliateClick @relation(fields: [clickId], references: [id])
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  amount        Float
  commission    Float
  commissionRate Float
  status        String   @default("PENDING") // PENDING | VALID | REFUNDED
  createdAt   DateTime @default(now())
  affiliateCommission AffiliateCommission?
}

model AffiliateCommission {
  id           String   @id @default(cuid())
  affiliateId  String
  affiliate    AffiliateProfile @relation(fields: [affiliateId], references: [id])
  conversionId String   @unique
  conversion   AffiliateConversion @relation(fields: [conversionId], references: [id])
  amount       Float
  rate         Float
  status       String   @default("PENDING") // PENDING | RELEASED | PAID | REFUNDED
  releasedAt   DateTime?
  paidAt       DateTime?
  createdAt    DateTime @default(now())
}

model AffiliatePayout {
  id            String   @id @default(cuid())
  affiliateId   String
  affiliate     AffiliateProfile @relation(fields: [affiliateId], references: [id])
  amount        Float
  fee           Float    @default(0)
  netAmount     Float
  method        String?  // bkash | nagad | bank
  accountNumber String?
  status        String   @default("PENDING") // PENDING | PROCESSING | COMPLETED | FAILED
  reference     String?
  processedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AffiliateCampaign {
  id             String   @id @default(cuid())
  affiliateId    String
  affiliate      AffiliateProfile @relation(fields: [affiliateId], references: [id])
  name           String
  budget         Float?
  spent          Float    @default(0)
  targetProducts String[]
  startDate      DateTime?
  endDate        DateTime?
  status         String   @default("ACTIVE") // ACTIVE | PAUSED | ENDED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// =================== PUSH NOTIFICATIONS ===================

model PushDevice {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  token       String   @unique
  platform    String   // ios | android | web
  isActive    Boolean  @default(true)
  pushEnabled Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs        PushLog[]
}

model PushLog {
  id        String   @id @default(cuid())
  userId    String
  deviceId  String
  device    PushDevice @relation(fields: [deviceId], references: [id])
  title     String
  body      String
  data      Json?
  status    String   // SENT | FAILED | DELIVERED | OPENED
  error     String?
  openedAt  DateTime?
  createdAt DateTime @default(now())
}

// =================== ADMIN LOGS ===================

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  action    String   // CREATE | UPDATE | DELETE | APPROVE | REJECT | LOGIN
  entity    String   // product | order | user | seller
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
}

// =================== DEVELOPER PLATFORM ===================

model ApiKey {
  id          String      @id @default(cuid())
  name        String
  key         String      @unique
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  permissions String[]
  isActive    Boolean     @default(true)
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  usageLogs   ApiUsageLog[]
}

model ApiUsageLog {
  id        String   @id @default(cuid())
  apiKeyId  String
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id])
  endpoint  String
  status    Int
  duration  Int
  ipAddress String?
  createdAt DateTime @default(now())
}

model Webhook {
  id        String       @id @default(cuid())
  storeId   String
  event     String
  url       String
  secret    String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  logs      WebhookLog[]
}

model WebhookLog {
  id           String   @id @default(cuid())
  webhookId    String
  webhook      Webhook  @relation(fields: [webhookId], references: [id])
  event        String
  status       Int
  duration     Int
  responseBody String?
  createdAt    DateTime @default(now())
}
